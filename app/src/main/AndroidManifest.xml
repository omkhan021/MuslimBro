<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Alarms — USE_EXACT_ALARM is auto-granted on API 33+, no user prompt required -->
    <!-- NEVER use SCHEDULE_EXACT_ALARM which requires manual user approval in Settings on API 31+ -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Notifications — runtime permission on API 33+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Boot + system events for alarm rescheduling -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Hardware -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".MuslimBroApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MuslimBro">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Prayer Alarm Service — foregroundServiceType=mediaPlayback for adhan audio -->
        <service
            android:name="com.muslimbro.feature.alarms.service.PrayerAlarmService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Quran Player Service — Media3 MediaSessionService -->
        <service
            android:name="com.muslimbro.feature.quranplayer.QuranPlayerService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback"
            tools:ignore="Instantiatable">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- Prayer Alarm BroadcastReceiver -->
        <receiver
            android:name="com.muslimbro.feature.alarms.receiver.PrayerAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.muslimbro.ACTION_PRAYER_ALARM" />
            </intent-filter>
        </receiver>

        <!-- Boot / Timezone / Time receivers for alarm rescheduling -->
        <receiver
            android:name="com.muslimbro.feature.alarms.receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>

        <!-- Small (2×1) Prayer Times Widget -->
        <receiver
            android:name="com.muslimbro.feature.widget.PrayerTimesWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_small_info" />
        </receiver>

        <!-- Medium (4×2) Prayer Times Widget -->
        <receiver
            android:name="com.muslimbro.feature.widget.PrayerTimesWidgetMediumReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_medium_info" />
        </receiver>

        <!-- WorkManager — manual init required for Hilt (remove default initializer) -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
